{
    "name": "after-agent-back",
    "version": "1.0.0",
    "description": "AI interviewer for tech roles",
    "main": "index.js",
    "_moduleAliases": {
        "@": "dist",
        "@app": "dist/app",
        "@controllers": "dist/controllers",
        "@lib": "dist/lib",
        "@constants": "dist/lib/constants",
        "@instances": "dist/lib/instances",
        "@interfaces": "dist/lib/interfaces",
        "@utils": "dist/lib/utils",
        "@zod": "dist/lib/zod",
        "@middlewares": "dist/middlewares",
        "@routes": "dist/routes",
        "@schemas": "dist/schemas",
        "@seed": "dist/seed",
        "@services": "dist/services"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx watch --clear-screen=false src/index.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "seed": "tsx src/seed/index.ts",
        "start": "node -r module-alias/register dist/index.js"
    },
    "keywords": [
        "node",
        "ai",
        "llm",
        "interviewer",
        "job"
    ],
    "author": "Pablo Beltran",
    "license": "ISC",
    "dependencies": {
        "@openrouter/sdk": "^0.13.22",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "google-auth-library": "^10.9.0",
        "jsonwebtoken": "^9.0.3",
        "module-alias": "^2.3.4",
        "mongodb": "^7.4.0",
        "mongoose": "^9.7.3",
        "multer": "^2.2.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/module-alias": "^2.0.4",
        "@types/multer": "^2.2.0",
        "@types/node": "^26.1.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-config-xo": "^0.56.0",
        "eslint-plugin-prettier": "^5.5.6",
        "globals": "^17.7.0",
        "prettier": "^3.9.4",
        "tsx": "^4.22.5",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1"
    }
}
