# Application variables
PORT=3000
NODE_ENV=development
CORS_WHITELIST=https://your-frontend-domain.com

# MongoDB variables
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=after-agent

# OpenRouter variables
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_INTERVIEWER_MODEL=google/gemini-2.5-flash
OPENROUTER_EVALUATION_MODEL=google/gemini-2.5-pro
OPENROUTER_STT_MODEL=openai/whisper-1
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE=Zephyr
OPENROUTER_TTS_RESPONSE_FORMAT=pcm

# Auth variables
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
